<script>
  // 统计组件初始化脚本

  document.addEventListener('DOMContentLoaded', () => {
    // 初始化 GitHub 贡献图滑动功能
    initCalendarScroll('github');
    // 初始化 LeetCode 贡献图滑动功能
    initCalendarScroll('leetcode');
  });

  // 通用的日历滑动初始化函数
  function initCalendarScroll(type: string) {
    const scrollContainer = document.getElementById(`${type}-scroll-container`);
    const yearsContainer = document.getElementById(`${type}-calendar-years`);
    const grid = document.getElementById(`${type}-calendar-grid`);

    if (!scrollContainer || !yearsContainer || !grid) return;

    const yearElements = yearsContainer.querySelectorAll(`.${type}-calendar__year`);

    const yearRanges: { element: HTMLElement; startPx: number; endPx: number; yearWidth: number }[] = [];
    yearElements.forEach((el) => {
      const yearEl = el as HTMLElement;
      const yearWidth = yearEl.offsetWidth;
      const startPx = parseFloat(yearEl.dataset.startPx || '0');
      const endPx = parseFloat(yearEl.dataset.endPx || '0');
      yearRanges.push({ element: yearEl, startPx, endPx, yearWidth });
    });

    let rafId: number | null = null;
    let lastScrollLeft = -1;

    function updateYearPositions() {
      const scrollLeft = scrollContainer!.scrollLeft;
      if (scrollLeft === lastScrollLeft) return;
      lastScrollLeft = scrollLeft;

      const containerWidth = scrollContainer!.clientWidth;

      yearRanges.forEach(({ element, startPx, endPx }) => {
        const yearWidth = element.offsetWidth;
        const visibleStart = scrollLeft;
        const visibleEnd = scrollLeft + containerWidth;

        let labelPosition = startPx;
        if (startPx < visibleStart) {
          labelPosition = Math.min(visibleStart, endPx - yearWidth);
        }

        const isVisible = (endPx > visibleStart && startPx < visibleEnd);
        const opacity = isVisible ? '1' : '0.3';

        element.style.transform = `translateX(${labelPosition}px)`;
        element.style.opacity = opacity;
      });
    }

    function scheduleUpdate() {
      if (rafId !== null) return;
      rafId = requestAnimationFrame(() => {
        updateYearPositions();
        rafId = null;
      });
    }

    scrollContainer.addEventListener('scroll', scheduleUpdate, { passive: true });
    updateYearPositions();

    setTimeout(() => {
      scrollContainer!.scrollLeft = scrollContainer!.scrollWidth;
      updateYearPositions();
    }, 100);

    const scrollHint = document.querySelector(`.${type}-calendar__scroll-hint`);
    let hintHidden = false;

    scrollContainer.addEventListener('scroll', () => {
      if (!hintHidden && scrollHint) {
        scrollHint.style.opacity = '0';
        setTimeout(() => {
          scrollHint.style.display = 'none';
        }, 300);
        hintHidden = true;
      }
    });

    let isDown = false;
    let startX = 0;
    let scrollLeftPos = 0;

    scrollContainer.addEventListener('mousedown', (e) => {
      isDown = true;
      scrollContainer.style.cursor = 'grabbing';
      startX = e.pageX - scrollContainer.offsetLeft;
      scrollLeftPos = scrollContainer.scrollLeft;
    });

    scrollContainer.addEventListener('mouseleave', () => {
      isDown = false;
      scrollContainer.style.cursor = 'grab';
    });

    scrollContainer.addEventListener('mouseup', () => {
      isDown = false;
      scrollContainer.style.cursor = 'grab';
    });

    scrollContainer.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - scrollContainer.offsetLeft;
      const walk = (x - startX) * 1.5;
      scrollContainer.scrollLeft = scrollLeftPos - walk;
    });
  }
</script>

