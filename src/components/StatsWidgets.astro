---
// 统计组件集合：GitHub Calendar、LeetCode Card、ClustrMaps
// GitHub 用户名: jiafeng-yan
// LeetCode 中国站用户名: anagke-59

import leetcodeData from '../data/leetcode.json';
import githubData from '../data/github.json';

const leetcode = leetcodeData as {
  username: string;
  solvedCount: number;
  totalQuestions: number;
  easySolved: number;
  easyTotal: number;
  mediumSolved: number;
  mediumTotal: number;
  hardSolved: number;
  hardTotal: number;
  ranking: number;
  contributionPoints: number;
  totalActiveDays: number;
  recentYearActiveDays: number;
  currentStreak: number;
  maxStreak: number;
  activeYears: number[];
  yearlyData: Record<number, { totalActiveDays: number; streak: number }>;
  submissionCalendar: Record<string, number>;
  scrapedAt: string;
};

const github = githubData as {
  username: string;
  userStats: {
    publicRepos: number;
    followers: number;
    following: number;
    createdAt: string | null;
    avatarUrl: string | null;
    bio: string | null;
    location: string | null;
  } | null;
  contributions: Record<string, number>;
  totalContributions: number;
  yearlyStats: Record<number, { total: number; weeks: number }>;
  activeDays: number;
  scrapedAt: string;
  tokenUsed: boolean;
};

// 生成 GitHub 贡献图数据（所有历史数据）
function generateGitHubCalendar(contributions: Record<string, number>) {
  const timestamps = Object.keys(contributions).map(Number).sort((a, b) => a - b);

  if (timestamps.length === 0) {
    return [];
  }

  const earliestTimestamp = timestamps[0];
  const latestTimestamp = timestamps[timestamps.length - 1];

  const earliestDate = new Date(earliestTimestamp * 1000);
  const latestDate = new Date(latestTimestamp * 1000);

  const startDate = new Date(Date.UTC(
    earliestDate.getUTCFullYear(),
    earliestDate.getUTCMonth(),
    earliestDate.getUTCDate()
  ));
  startDate.setUTCDate(startDate.getUTCDate() - startDate.getUTCDay());

  const endDate = new Date(Date.UTC(
    latestDate.getUTCFullYear(),
    latestDate.getUTCMonth(),
    latestDate.getUTCDate()
  ));
  endDate.setUTCDate(endDate.getUTCDate() + (6 - endDate.getUTCDay()));

  const daysDiff = Math.floor((endDate.getTime() - startDate.getTime()) / (1000 * 60 * 60 * 24));
  const weeksCount = Math.ceil((daysDiff + 1) / 7);

  const daysPerWeek = 7;
  const cells: { date: Date; count: number; level: number }[] = [];

  for (let w = 0; w < weeksCount; w++) {
    for (let d = 0; d < daysPerWeek; d++) {
      const cellDate = new Date(startDate);
      cellDate.setUTCDate(cellDate.getUTCDate() + w * 7 + d);

      const timestamp = Math.floor(Date.UTC(
        cellDate.getUTCFullYear(),
        cellDate.getUTCMonth(),
        cellDate.getUTCDate()
      ) / 1000);

      const count = contributions[timestamp.toString()] || 0;

      let level = 0;
      if (count > 0) level = 1;
      if (count >= 4) level = 2;
      if (count >= 8) level = 3;
      if (count >= 12) level = 4;

      cells.push({ date: cellDate, count, level });
    }
  }

  return { cells, weeksCount };
}

// GitHub 月份标签
function getGitHubMonthLabels(weeksCount: number, contributions: Record<string, number>) {
  const timestamps = Object.keys(contributions).map(Number).sort((a, b) => a - b);

  if (timestamps.length === 0) {
    return [];
  }

  const earliestTimestamp = timestamps[0];
  const earliestDate = new Date(earliestTimestamp * 1000);

  const startDate = new Date(Date.UTC(
    earliestDate.getUTCFullYear(),
    earliestDate.getUTCMonth(),
    earliestDate.getUTCDate()
  ));
  startDate.setUTCDate(startDate.getUTCDate() - startDate.getUTCDay());

  const months: { label: string; weekIndex: number; year: number; width: number }[] = [];

  let currentMonth = -1;
  let currentYear = -1;
  let prevWeekIndex = 0;

  for (let w = 0; w < weeksCount; w++) {
    const weekDate = new Date(startDate);
    weekDate.setUTCDate(weekDate.getUTCDate() + w * 7);

    const month = weekDate.getUTCMonth();
    const year = weekDate.getUTCFullYear();

    if (month !== currentMonth || year !== currentYear) {
      if (currentMonth !== -1) {
        const lastMonthWidth = (w - prevWeekIndex) * 12;
        months[months.length - 1].width = lastMonthWidth;
      }
      currentMonth = month;
      currentYear = year;
      prevWeekIndex = w;
      const monthName = weekDate.toLocaleDateString('zh-CN', { month: 'short' });
      months.push({
        label: monthName,
        weekIndex: w,
        year: year,
        width: 0
      });
    }
  }

  if (months.length > 0) {
    months[months.length - 1].width = (weeksCount - prevWeekIndex) * 12;
  }

  return months;
}

// GitHub 年份标签
function getGitHubYearLabels(monthLabels: { label: string; weekIndex: number; year: number; width: number }[], weeksCount: number) {
  const years: { label: string; weekIndex: number; width: number }[] = [];
  let currentYear = -1;
  let yearStartWeekIndex = 0;

  for (let i = 0; i < monthLabels.length; i++) {
    const month = monthLabels[i];
    if (month.year !== currentYear) {
      if (currentYear !== -1) {
        const lastYearWidth = (month.weekIndex - yearStartWeekIndex) * 12;
        years[years.length - 1].width = lastYearWidth;
      }
      currentYear = month.year;
      yearStartWeekIndex = month.weekIndex;
      years.push({
        label: `${month.year}年`,
        weekIndex: month.weekIndex,
        width: 0
      });
    }
  }

  if (years.length > 0) {
    years[years.length - 1].width = (weeksCount - yearStartWeekIndex) * 12;
  }

  return years;
}

// 生成 LeetCode 贡献图数据（所有历史数据）
function generateLeetCodeCalendar(calendar: Record<string, number>) {
  // 获取日历数据中的所有时间戳
  const timestamps = Object.keys(calendar).map(Number).sort((a, b) => a - b);

  if (timestamps.length === 0) {
    // 如果没有数据，返回空数组
    return [];
  }

  // 计算最早和最晚的日期
  const earliestTimestamp = timestamps[0];
  const latestTimestamp = timestamps[timestamps.length - 1];

  const earliestDate = new Date(earliestTimestamp * 1000);
  const latestDate = new Date(latestTimestamp * 1000);

  // 计算起始日期（调整到周日）
  const startDate = new Date(Date.UTC(
    earliestDate.getUTCFullYear(),
    earliestDate.getUTCMonth(),
    earliestDate.getUTCDate()
  ));
  startDate.setUTCDate(startDate.getUTCDate() - startDate.getUTCDay());

  // 计算结束日期（调整到周六）
  const endDate = new Date(Date.UTC(
    latestDate.getUTCFullYear(),
    latestDate.getUTCMonth(),
    latestDate.getUTCDate()
  ));
  endDate.setUTCDate(endDate.getUTCDate() + (6 - endDate.getUTCDay()));

  // 计算总周数
  const daysDiff = Math.floor((endDate.getTime() - startDate.getTime()) / (1000 * 60 * 60 * 24));
  const weeksCount = Math.ceil((daysDiff + 1) / 7);

  const daysPerWeek = 7;
  const cells: { date: Date; count: number; level: number }[] = [];

  for (let w = 0; w < weeksCount; w++) {
    for (let d = 0; d < daysPerWeek; d++) {
      const cellDate = new Date(startDate);
      cellDate.setUTCDate(cellDate.getUTCDate() + w * 7 + d);

      // 转换为 Unix 时间戳（秒）- 使用 UTC 午夜时间
      const timestamp = Math.floor(Date.UTC(
        cellDate.getUTCFullYear(),
        cellDate.getUTCMonth(),
        cellDate.getUTCDate()
      ) / 1000);

      const count = calendar[timestamp.toString()] || 0;

      // 计算颜色等级 (0-4)
      let level = 0;
      if (count > 0) level = 1;
      if (count >= 4) level = 2;
      if (count >= 8) level = 3;
      if (count >= 12) level = 4;

      cells.push({ date: cellDate, count, level });
    }
  }

  return { cells, weeksCount };
}

// 获取月份标签（根据实际周数，只显示月份）
function getMonthLabels(weeksCount: number, calendar: Record<string, number>) {
  const timestamps = Object.keys(calendar).map(Number).sort((a, b) => a - b);

  if (timestamps.length === 0) {
    return [];
  }

  const earliestTimestamp = timestamps[0];
  const earliestDate = new Date(earliestTimestamp * 1000);

  // 计算起始日期（调整到周日）
  const startDate = new Date(Date.UTC(
    earliestDate.getUTCFullYear(),
    earliestDate.getUTCMonth(),
    earliestDate.getUTCDate()
  ));
  startDate.setUTCDate(startDate.getUTCDate() - startDate.getUTCDay());

  const months: { label: string; weekIndex: number; year: number; width: number }[] = [];

  let currentMonth = -1;
  let currentYear = -1;
  let prevWeekIndex = 0;

  for (let w = 0; w < weeksCount; w++) {
    const weekDate = new Date(startDate);
    weekDate.setUTCDate(weekDate.getUTCDate() + w * 7);

    const month = weekDate.getUTCMonth();
    const year = weekDate.getUTCFullYear();

    if (month !== currentMonth || year !== currentYear) {
      if (currentMonth !== -1) {
        // 计算上一个月的宽度（从上一个月份起始周到当前周）
        const lastMonthWidth = (w - prevWeekIndex) * 12;
        months[months.length - 1].width = lastMonthWidth;
      }
      currentMonth = month;
      currentYear = year;
      prevWeekIndex = w;
      // 只显示月份（如 "5月"）
      const monthName = weekDate.toLocaleDateString('zh-CN', { month: 'short' });
      months.push({
        label: monthName,
        weekIndex: w,
        year: year,
        width: 0 // 将在下一个月份或结束时计算
      });
    }
  }

  // 计算最后一个月份的宽度
  if (months.length > 0) {
    months[months.length - 1].width = (weeksCount - prevWeekIndex) * 12;
  }

  return months;
}

// 获取年份标签（根据月份标签计算）
function getYearLabels(monthLabels: { label: string; weekIndex: number; year: number; width: number }[], weeksCount: number) {
  const years: { label: string; weekIndex: number; width: number }[] = [];
  let currentYear = -1;
  let yearStartWeekIndex = 0;

  for (let i = 0; i < monthLabels.length; i++) {
    const month = monthLabels[i];
    if (month.year !== currentYear) {
      if (currentYear !== -1) {
        // 计算上一个年份的宽度（从上一个年份起始周到当前周）
        const lastYearWidth = (month.weekIndex - yearStartWeekIndex) * 12;
        years[years.length - 1].width = lastYearWidth;
      }
      currentYear = month.year;
      yearStartWeekIndex = month.weekIndex;
      years.push({
        label: `${month.year}年`,
        weekIndex: month.weekIndex,
        width: 0 // 将在下一个年份或结束时计算
      });
    }
  }

  // 计算最后一个年份的宽度
  if (years.length > 0) {
    years[years.length - 1].width = (weeksCount - yearStartWeekIndex) * 12;
  }

  return years;
}

// 生成日历数据
const leetcodeCalendarResult = leetcode.submissionCalendar ? generateLeetCodeCalendar(leetcode.submissionCalendar) : null;
const leetcodeCalendar = leetcodeCalendarResult?.cells || [];
const leetcodeWeeksCount = leetcodeCalendarResult?.weeksCount || 53;
const leetcodeMonthLabels = leetcode.submissionCalendar ? getMonthLabels(leetcodeWeeksCount, leetcode.submissionCalendar) : [];
const leetcodeYearLabels = getYearLabels(leetcodeMonthLabels, leetcodeWeeksCount);

// GitHub 日历数据
const githubCalendarResult = github.contributions && Object.keys(github.contributions).length > 0
  ? generateGitHubCalendar(github.contributions)
  : null;
const githubCalendar = githubCalendarResult?.cells || [];
const githubWeeksCount = githubCalendarResult?.weeksCount || 53;
const githubMonthLabels = github.contributions && Object.keys(github.contributions).length > 0
  ? getGitHubMonthLabels(githubWeeksCount, github.contributions)
  : [];
const githubYearLabels = getGitHubYearLabels(githubMonthLabels, githubWeeksCount);

const dayLabels = ['日', '一', '二', '三', '四', '五', '六'];
---

<section class="stats-widgets" id="stats" aria-labelledby="stats-title">
  <div class="stats-widgets__header">
    <span class="section-kicker">Activity</span>
    <h2 id="stats-title">动态统计</h2>
    <p>开源贡献、刷题记录与访客分布的可视化展示。</p>
  </div>

  <div class="stats-widgets__grid">
    <!-- 第一行：GitHub + 访客地图 -->
    <div class="stats-row stats-row--top">
      <!-- GitHub Contribution Chart -->
      <div class="stats-widget stats-widget--github">
        <div class="stats-widget__header">
          <span class="stats-widget__icon">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.05 1.77 2.745 1.275 3.42.96.105-.78.42-1.275.765-1.575-2.67-.3-5.46-1.335-5.46-5.925 0-1.335.48-2.43 1.23-3.3-.12-.3-.54-1.56.12-3.255 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.695.24 2.955.12 3.255.765.87 1.23 1.965 1.23 3.3 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </span>
          <h3 class="stats-widget__title">GitHub 贡献</h3>
          <a href="https://github.com/jiafeng-yan" target="_blank" rel="noopener noreferrer" class="github-link-badge">
            @jiafeng-yan →
          </a>
        </div>
        <div class="stats-widget__content stats-widget__content--calendar">
          {githubCalendar.length > 0 ? (
            <div class="github-stats">
              <!-- GitHub 统计摘要 -->
              <div class="github-stats__summary">
                <div class="github-stats__summary-item">
                  <span class="github-stats__summary-value">{github.totalContributions.toLocaleString()}</span>
                  <span class="github-stats__summary-label">总贡献</span>
                </div>
                <div class="github-stats__summary-item">
                  <span class="github-stats__summary-value">{github.activeDays}</span>
                  <span class="github-stats__summary-label">活跃天数</span>
                </div>
                {github.userStats && (
                  <div class="github-stats__summary-item">
                    <span class="github-stats__summary-value">{github.userStats.publicRepos}</span>
                    <span class="github-stats__summary-label">公开仓库</span>
                  </div>
                )}
              </div>

              <!-- GitHub 贡献图（瓷砖墙）- 可滑动 -->
              <div class="github-calendar" id="github-calendar">
                <div class="github-calendar__scroll-container" id="github-scroll-container">
                  <!-- 年份标签层 -->
                  <div class="github-calendar__years" id="github-calendar-years">
                    {githubYearLabels.map((year, i) => (
                      <span class="github-calendar__year" key={i} data-start-px={18 + year.weekIndex * 12} data-end-px={18 + (year.weekIndex * 12) + year.width}>{year.label}</span>
                    ))}
                  </div>
                  <!-- 月份标签层 -->
                  <div class="github-calendar__header" id="github-calendar-header">
                    {githubMonthLabels.map((month, i) => (
                      <span class="github-calendar__month" key={i} style={`width: ${month.width}px;`}>{month.label}</span>
                    ))}
                  </div>
                  <div class="github-calendar__body">
                    <div class="github-calendar__day-labels">
                      {dayLabels.map((day, i) => (
                        <span class="github-calendar__day-label" key={i}>{i % 2 === 0 ? day : ''}</span>
                      ))}
                    </div>
                    <div class="github-calendar__grid" id="github-calendar-grid" style={`width: calc(${githubWeeksCount} * 12px - 2px); min-width: calc(${githubWeeksCount} * 12px - 2px);`}>
                      {githubCalendar.map((cell, i) => (
                        <div
                          class={`github-calendar__cell github-calendar__cell--level-${cell.level}`}
                          key={i}
                          title={`${cell.date.toLocaleDateString('zh-CN')}: ${cell.count} 次贡献`}
                          data-count={cell.count}
                        ></div>
                      ))}
                    </div>
                  </div>
                </div>
                <div class="github-calendar__scroll-hint">
                  <span class="github-calendar__scroll-hint-text">← 滑动查看更多 →</span>
                </div>
                <div class="github-calendar__legend">
                  <span class="github-calendar__legend-text">少</span>
                  {[0, 1, 2, 3, 4].map(level => (
                    <div class={`github-calendar__cell github-calendar__cell--level-${level}`} key={level}></div>
                  ))}
                  <span class="github-calendar__legend-text">多</span>
                </div>
              </div>

              <!-- 私有仓库提示 -->
              {github.tokenUsed && (
                <p class="github-calendar__note">包含私有仓库贡献</p>
              )}
            </div>
          ) : (
            <div class="github-stats github-stats--fallback">
              <img
                src="https://ghchart.rshah.org/jiafeng-yan"
                alt="GitHub 贡献图表"
                loading="lazy"
              />
              <p class="github-calendar__note">过去一年的代码贡献记录</p>
            </div>
          )}
        </div>
      </div>

      <!-- ClustrMaps 访客地图 -->
      <div class="stats-widget stats-widget--clustrmaps">
        <div class="stats-widget__header">
          <span class="stats-widget__icon">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
            </svg>
          </span>
          <h3 class="stats-widget__title">访客地图</h3>
        </div>
        <div class="stats-widget__content stats-widget__content--clustrmaps">
          <div class="clustrmaps-container" id="clustrmaps-container">
            <script type="text/javascript" id="clustrmaps" src="//clustrmaps.com/map_v2.js?d=E_bP5hegmjAHoYl1b8nwWh0E3o6VQuu3n_b04jgxl3U&cl=ffffff&w=a"></script>
          </div>
        </div>
      </div>
    </div>

    <!-- 第二行：LeetCode 单独一排 -->
    <div class="stats-row stats-row--bottom">
      <div class="stats-widget stats-widget--leetcode">
        <div class="stats-widget__header">
          <span class="stats-widget__icon leetcode-icon">
            <img
              src="https://static.leetcode.cn/cn-frontendx-assets/production/_next/static/images/logo-ff2b712834cf26bf50a5de58ee27bcef.png"
              alt="LeetCode"
              width="20"
              height="20"
              loading="lazy"
            />
          </span>
          <h3 class="stats-widget__title">LeetCode 刷题</h3>
          <a href="https://leetcode.cn/u/anagke-59/" target="_blank" rel="noopener noreferrer" class="leetcode-link-badge">
            @ΑΝΑΓΚΗ →
          </a>
        </div>
        <div class="stats-widget__content stats-widget__content--leetcode">
          {leetcode.solvedCount > 0 ? (
            <div class="leetcode-stats">
              <!-- 统计摘要 -->
              <div class="leetcode-stats__summary">
                <div class="leetcode-stats__summary-item">
                  <span class="leetcode-stats__summary-value">{leetcode.solvedCount}</span>
                  <span class="leetcode-stats__summary-label">已解决</span>
                </div>
                <div class="leetcode-stats__summary-item">
                  <span class="leetcode-stats__summary-value">{leetcode.recentYearActiveDays || leetcode.totalActiveDays}</span>
                  <span class="leetcode-stats__summary-label">最近一年活跃</span>
                </div>
                <div class="leetcode-stats__summary-item">
                  <span class="leetcode-stats__summary-value">{leetcode.totalActiveDays}</span>
                  <span class="leetcode-stats__summary-label">总活跃天数</span>
                </div>
                <div class="leetcode-stats__summary-item">
                  <span class="leetcode-stats__summary-value leetcode-stats__summary-value--streak">{leetcode.maxStreak || leetcode.currentStreak}</span>
                  <span class="leetcode-stats__summary-label">最长连续</span>
                </div>
              </div>

              <!-- LeetCode 贡献图（瓷砖墙）- 可滑动 -->
              <div class="leetcode-calendar" id="leetcode-calendar">
                <div class="leetcode-calendar__scroll-container" id="leetcode-scroll-container">
                  <!-- 年份标签层 -->
                  <div class="leetcode-calendar__years" id="leetcode-calendar-years">
                    {leetcodeYearLabels.map((year, i) => (
                      <span class="leetcode-calendar__year" key={i} data-start-px={18 + year.weekIndex * 12} data-end-px={18 + (year.weekIndex * 12) + year.width}>{year.label}</span>
                    ))}
                  </div>
                  <!-- 月份标签层 -->
                  <div class="leetcode-calendar__header" id="leetcode-calendar-header">
                    {leetcodeMonthLabels.map((month, i) => (
                      <span class="leetcode-calendar__month" key={i} style={`width: ${month.width}px;`}>{month.label}</span>
                    ))}
                  </div>
                  <div class="leetcode-calendar__body">
                    <div class="leetcode-calendar__day-labels">
                      {dayLabels.map((day, i) => (
                        <span class="leetcode-calendar__day-label" key={i}>{i % 2 === 0 ? day : ''}</span>
                      ))}
                    </div>
                    <div class="leetcode-calendar__grid" id="leetcode-calendar-grid" style={`width: calc(${leetcodeWeeksCount} * 12px - 2px); min-width: calc(${leetcodeWeeksCount} * 12px - 2px);`}>
                      {leetcodeCalendar.map((cell, i) => (
                        <div
                          class={`leetcode-calendar__cell leetcode-calendar__cell--level-${cell.level}`}
                          key={i}
                          title={`${cell.date.toLocaleDateString('zh-CN')}: ${cell.count} 题`}
                          data-count={cell.count}
                        ></div>
                      ))}
                    </div>
                  </div>
                </div>
                <div class="leetcode-calendar__scroll-hint">
                  <span class="leetcode-calendar__scroll-hint-text">← 滑动查看更多 →</span>
                </div>
                <div class="leetcode-calendar__legend">
                  <span class="leetcode-calendar__legend-text">少</span>
                  {[0, 1, 2, 3, 4].map(level => (
                    <div class={`leetcode-calendar__cell leetcode-calendar__cell--level-${level}`} key={level}></div>
                  ))}
                  <span class="leetcode-calendar__legend-text">多</span>
                </div>
              </div>

              <!-- 难度分布 -->
              <div class="leetcode-stats__progress">
                <div class="leetcode-progress-item leetcode-progress-item--easy">
                  <div class="leetcode-progress-item__header">
