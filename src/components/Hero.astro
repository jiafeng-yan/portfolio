---
// src/components/Hero.astro
---

<section class="hero" data-section="hero" aria-labelledby="hero-name">
  <div class="hero__content">
    <div class="hero__badge">
      <span class="hero__badge-dot"></span>
      <span>Open to Opportunities</span>
    </div>

    <p class="hero__eyebrow">Computer Vision · Multimodal AI · CUFE</p>
    <h1 class="hero__name" id="hero-name">
      <span class="hero__name-first">闫</span>
      <span class="hero__name-last">家锋</span>
    </h1>

    <p class="hero__title">计算机科学与技术本科生 · 已保研至中央财经大学</p>
    <p class="hero__subtitle">图像融合 / 多退化恢复 / 遥感推理分割 / RAG 应用</p>

    <div class="hero__stats">
      <div class="hero__stat">
        <span class="hero__stat-value">AAAI</span>
        <span class="hero__stat-label">2026 Poster</span>
      </div>
      <div class="hero__stat-divider"></div>
      <div class="hero__stat">
        <span class="hero__stat-value">3.76</span>
        <span class="hero__stat-label">GPA / 4.5</span>
      </div>
      <div class="hero__stat-divider"></div>
      <div class="hero__stat">
        <span class="hero__stat-value">Top 5.8%</span>
        <span class="hero__stat-label">CSP 认证</span>
      </div>
    </div>

    <p class="hero__intro">
      加权排名 <strong>4/30</strong>，综测排名 <strong>3/30</strong>。围绕红外-可见光融合、多模态视觉理解与检索增强应用做研究和工程原型，
      已有 <strong>AAAI 2026 Poster</strong>、arXiv 预印本与多个投稿中工作。
    </p>

    <div class="hero__links" aria-label="联系方式">
      <a href="https://github.com/jiafeng-yan" target="_blank" rel="noopener noreferrer" data-cursor-hover class="hero__link hero__link--primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.835 1.305 3.51.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        GitHub
      </a>
      <a href="mailto:yan.jiafeng@email.cufe.edu.cn" data-cursor-hover class="hero__link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="M22 6L12 13 2 6"/>
        </svg>
        Email
      </a>
      <a href="tel:+8613935252657" data-cursor-hover class="hero__link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
        </svg>
        Phone
      </a>
    </div>
  </div>

  <div class="hero__signal" aria-hidden="true">
    <span class="hero__signal-ring hero__signal-ring--outer"></span>
    <span class="hero__signal-ring hero__signal-ring--middle"></span>
    <span class="hero__signal-ring hero__signal-ring--inner"></span>
    <span class="hero__signal-dot"></span>
  </div>

  <div class="hero__scroll-indicator" aria-hidden="true">
    <div class="hero__scroll-ripples">
      <div class="hero__scroll-ripple hero__scroll-ripple--1"></div>
      <div class="hero__scroll-ripple hero__scroll-ripple--2"></div>
      <div class="hero__scroll-ripple hero__scroll-ripple--3"></div>
    </div>
    <span>Scroll</span>
    <div class="hero__scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-xl);
    position: relative;
    overflow: hidden;
  }

  .hero__content {
    max-width: 820px;
    position: relative;
    z-index: 1;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 6px 14px;
    background: rgba(34, 197, 94, 0.08);
    border: 1px solid rgba(34, 197, 94, 0.2);
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 500;
    color: #16a34a;
    margin-bottom: var(--space-lg);
    animation: badgePulse 3s ease-in-out infinite;
  }

  .hero__badge-dot {
    width: 8px;
    height: 8px;
    background: #22c55e;
    border-radius: 50%;
    animation: dotPulse 2s ease-in-out infinite;
  }

  @keyframes badgePulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.85; }
  }

  @keyframes dotPulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.2); opacity: 0.7; }
  }

  .hero__eyebrow {
    font-family: var(--font-mono);
    color: var(--color-gray);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-md);
  }

  .hero__name {
    font-size: clamp(4rem, 12vw, 10rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-md);
  }

  .hero__name-first {
    display: block;
    color: var(--color-text);
  }

  .hero__name-last {
    display: block;
    color: var(--color-gray);
    margin-top: -0.1em;
  }

  .hero__title {
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    color: var(--color-beige);
    font-weight: 500;
    margin-bottom: var(--space-sm);
  }

  .hero__subtitle {
    font-size: clamp(1rem, 2vw, 1.18rem);
    color: var(--color-ink-blue);
    font-weight: 500;
    margin-bottom: var(--space-lg);
  }

  .hero__stats {
    display: inline-flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: var(--border-radius);
    margin-bottom: var(--space-lg);
    backdrop-filter: blur(8px);
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .hero__stat-value {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    font-family: var(--font-mono);
  }

  .hero__stat-label {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero__stat-divider {
    width: 1px;
    height: 32px;
    background: rgba(0, 0, 0, 0.12);
  }

  .hero__intro {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 620px;
    line-height: 1.85;
    margin-bottom: var(--space-lg);
  }

  .hero__intro strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .hero__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .hero__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.875rem;
    font-weight: 500;
    padding: var(--space-sm) var(--space-md);
    border: 1px solid rgba(0, 0, 0, 0.15);
    border-radius: var(--border-radius);
    background: rgba(255, 255, 255, 0.5);
    transition:
      background var(--duration-normal) var(--ease-out-expo),
      color var(--duration-normal) var(--ease-out-expo),
      border-color var(--duration-normal) var(--ease-out-expo),
      transform var(--duration-normal) var(--ease-out-expo),
      box-shadow var(--duration-normal) var(--ease-out-expo);
  }

  .hero__link--primary {
    background: var(--color-text);
    color: var(--color-bg);
    border-color: var(--color-text);
  }

  .hero__link:hover,
  .hero__link:focus-visible {
    background: var(--color-text);
    color: var(--color-bg);
    border-color: var(--color-text);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .hero__link--primary:hover,
  .hero__link--primary:focus-visible {
    background: #333;
    border-color: #333;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
  }

  .hero__signal {
    position: absolute;
    right: clamp(2rem, 8vw, 8rem);
    top: 50%;
    width: clamp(9rem, 20vw, 18rem);
    aspect-ratio: 1;
    transform: translateY(-50%);
    opacity: 0.62;
  }

  .hero__signal-ring,
  .hero__signal-dot {
    position: absolute;
    inset: 0;
    border-radius: 50%;
  }

  .hero__signal-ring {
    border: 1px solid rgba(160, 160, 160, 0.45);
    animation: signalDrift 7s ease-in-out infinite;
  }

  .hero__signal-ring--middle {
    inset: 18%;
    border-color: rgba(210, 180, 140, 0.52);
    animation-delay: -1.7s;
  }

  .hero__signal-ring--inner {
    inset: 34%;
    border-color: rgba(176, 196, 222, 0.58);
    animation-delay: -3.2s;
  }

  .hero__signal-dot {
    inset: 47%;
    background: var(--color-text);
    opacity: 0.7;
  }

  @keyframes signalDrift {
    0%, 100% {
      transform: rotate(0deg) scale(1);
      border-radius: 48% 52% 51% 49%;
    }
    50% {
      transform: rotate(12deg) scale(1.05);
      border-radius: 54% 46% 48% 52%;
    }
  }

  .hero__scroll-indicator {
    position: absolute;
    bottom: var(--space-xl);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.75rem;
    text-transform: uppercase;
    color: var(--color-gray);
    letter-spacing: 0.1em;
  }

  .hero__scroll-ripples {
    position: relative;
    width: 80px;
    height: 60px;
    margin-bottom: var(--space-sm);
  }

  .hero__scroll-ripple {
    position: absolute;
    border: 1px solid var(--color-gray);
    border-radius: 50%;
    opacity: 0;
    animation: ripplePulse 2s ease-out infinite;
  }

  .hero__scroll-ripple--1 {
    width: 80px;
    height: 24px;
    top: 0;
    left: 0;
    animation-delay: 0s;
  }

  .hero__scroll-ripple--2 {
    width: 60px;
    height: 18px;
    top: 20px;
    left: 10px;
    animation-delay: 0.3s;
  }

  .hero__scroll-ripple--3 {
    width: 40px;
    height: 12px;
    top: 40px;
    left: 20px;
    animation-delay: 0.6s;
  }

  @keyframes ripplePulse {
    0% {
      opacity: 0.6;
      transform: scale(0.8);
    }
    50% {
      opacity: 0.3;
    }
    100% {
      opacity: 0;
      transform: scale(1.2);
    }
  }

  .hero__scroll-line {
    width: 1px;
    height: 50px;
    background: linear-gradient(to bottom, var(--color-gray), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% {
      opacity: 0.3;
      transform: scaleY(1);
    }
    50% {
      opacity: 1;
      transform: scaleY(1.2);
    }
  }

  @media (max-width: 900px) {
    .hero {
      padding: var(--space-lg);
    }

    .hero__signal {
      right: -3rem;
      opacity: 0.3;
    }
  }

  @media (max-width: 640px) {
    .hero {
      min-height: 100svh;
      padding: var(--space-lg) var(--space-md);
      justify-content: center;
    }

    .hero__name {
      font-size: clamp(3.2rem, 18vw, 5.4rem);
    }

    .hero__title {
      font-size: 1rem;
    }

    .hero__subtitle,
    .hero__intro {
      font-size: 0.88rem;
    }

    .hero__intro {
      line-height: 1.75;
    }

    .hero__stats {
      flex-direction: column;
      gap: var(--space-sm);
      padding: var(--space-md);
    }

    .hero__stat-divider {
      width: 60%;
      height: 1px;
    }

    .hero__links {
      flex-direction: column;
      align-items: stretch;
      max-width: 15rem;
    }

    .hero__links a {
      text-align: center;
      justify-content: center;
    }

    .hero__signal {
      width: 11rem;
      top: auto;
      bottom: 9rem;
      right: -4.5rem;
      transform: none;
    }

    .hero__scroll-ripples {
      display: none;
    }

    .hero__scroll-line {
      height: 36px;
    }

    .hero__scroll-indicator {
      bottom: var(--space-lg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__badge,
    .hero__badge-dot,
    .hero__signal-ring,
    .hero__scroll-ripple,
    .hero__scroll-line {
      animation: none;
    }
  }
</style>
